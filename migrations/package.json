{
  "name": "migrations",
  "version": "1.0.0",
  "private": true,
  "description": "Knex migrations for the Smart Audit Interview Postgres schema",
  "scripts": {
    "make": "knex migrate:make",
    "up": "node scripts/migrate.js up",
    "down": "node scripts/migrate.js down",
    "migrate:up-all": "npx knex migrate:latest",
    "migrate:down-all": "npx knex migrate:rollback --all",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "knex": "^3.1.0",
    "pg": "^8.11.5"
  }
}
