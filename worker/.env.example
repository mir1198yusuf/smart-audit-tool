DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=smart_audit_interview
GEMINI_API_KEY=
# true for managed/remote Postgres (e.g. Aiven) that require SSL; false/omit for local Postgres
DB_SSL=false

# RUN_PING_SERVER controls whether the tiny keep-alive HTTP server (which listens on PORT) starts at all.
# When RUN_PING_SERVER is false, the server does not start. Some free-tier hosts sleep/kill processes
# with no inbound HTTP traffic, so when needed, set RUN_PING_SERVER=true and have an external uptime
# pinger hit GET /test on PORT to keep the process classified as active.
# keep it false for local development
PORT=3001
RUN_PING_SERVER=false
