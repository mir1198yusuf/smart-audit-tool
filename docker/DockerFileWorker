# Build context: worker/
# Dockerfile location: docker/DockerFileWorker
# Docker image build command to be run from: repo root
#   docker build -f docker/DockerFileWorker -t smart-audit-worker worker


FROM node:24-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

RUN npm run build

CMD ["node", "dist/index.js"]
